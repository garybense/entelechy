# Entelechy Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (Required)
# Supported providers: openai, groq, ollama, gemini, anthropic, lmstudio, vertexai, minimax, deepseek, volcano
ENTELECHY_API_LLM_PROVIDER=gemini
ENTELECHY_API_LLM_API_KEY="AIzaSyA3EZZK0-p9Ex2gXMz8roeVGEtf-_toETg"
ENTELECHY_API_LLM_MODEL=gemini-flash-latest
ENTELECHY_API_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Example: Anthropic Claude configuration
# ENTELECHY_API_LLM_PROVIDER=anthropic
# ENTELECHY_API_LLM_API_KEY=your-anthropic-api-key
# ENTELECHY_API_LLM_MODEL=claude-sonnet-4-20250514

# Example: Google Vertex AI configuration
# ENTELECHY_API_LLM_PROVIDER=vertexai
# ENTELECHY_API_LLM_MODEL=google/gemini-2.0-flash-001
# ENTELECHY_API_LLM_VERTEXAI_PROJECT_ID=your-gcp-project-id
# ENTELECHY_API_LLM_VERTEXAI_REGION=us-central1
# ENTELECHY_API_LLM_VERTEXAI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json  # Optional, uses ADC if not set

# Example: MiniMax configuration (1M context window)
# ENTELECHY_API_LLM_PROVIDER=minimax
# ENTELECHY_API_LLM_API_KEY=your-minimax-api-key
# ENTELECHY_API_LLM_MODEL=MiniMax-M2.7

# Example: DeepSeek configuration (https://api.deepseek.com)
# ENTELECHY_API_LLM_PROVIDER=deepseek
# ENTELECHY_API_LLM_API_KEY=your-deepseek-api-key
# ENTELECHY_API_LLM_MODEL=deepseek-v4-flash  # or deepseek-v4-pro / deepseek-chat / deepseek-reasoner

# Example: LM Studio local configuration (Qwen 2.5 32B recommended)
# ENTELECHY_API_LLM_PROVIDER=lmstudio
# ENTELECHY_API_LLM_API_KEY=lmstudio
# ENTELECHY_API_LLM_BASE_URL=http://localhost:1234/v1
# ENTELECHY_API_LLM_MODEL=qwen2.5-32b-instruct

# API Configuration (Optional)
ENTELECHY_API_HOST=0.0.0.0
ENTELECHY_API_PORT=8888
ENTELECHY_API_LOG_LEVEL=info

# Base Path / Reverse Proxy Support (Optional)
# Set these when deploying behind a reverse proxy with path-based routing
# Example: To deploy at example.com/entelechy/, set both to "/entelechy"
# ENTELECHY_API_BASE_PATH=/entelechy
# NEXT_PUBLIC_BASE_PATH=/entelechy

# Database (Optional - uses embedded pg0 by default)
# ENTELECHY_API_DATABASE_URL=postgresql://user:pass@host:5432/db
# ENTELECHY_API_MIGRATION_DATABASE_URL=  # Direct PostgreSQL URL for migrations (bypasses PgBouncer). Falls back to DATABASE_URL.
# ENTELECHY_API_DATABASE_SCHEMA=public  # PostgreSQL schema name (default: public)

# Vector Extension (Optional - uses pgvector by default)
# Options: "pgvector" (default), "vchord", "pgvectorscale" (DiskANN)
# ENTELECHY_API_VECTOR_EXTENSION=pgvector
# For Azure PostgreSQL with DiskANN:
# ENTELECHY_API_VECTOR_EXTENSION=pgvectorscale  # Auto-detects pg_diskann on Azure

# Embeddings Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ENTELECHY_API_EMBEDDINGS_PROVIDER=local
# For local provider:
# ENTELECHY_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
# For TEI provider:
# ENTELECHY_API_EMBEDDINGS_TEI_URL=http://localhost:8080

# Reranker Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ENTELECHY_API_RERANKER_PROVIDER=local
# For local provider:
# ENTELECHY_API_RERANKER_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# For TEI provider:
# ENTELECHY_API_RERANKER_TEI_URL=http://localhost:8081

# Observability & Tracing (Optional - disabled by default)
# Enable OpenTelemetry tracing for LLM calls (GenAI semantic conventions)
# ENTELECHY_API_OTEL_TRACES_ENABLED=true
#
# Local development with Grafana LGTM stack (recommended - see scripts/dev/grafana/README.md)
# ENTELECHY_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
# Cloud backends (Grafana Cloud, Langfuse, DataDog, etc.)
# ENTELECHY_API_OTEL_EXPORTER_OTLP_ENDPOINT=https://your-backend-url
# ENTELECHY_API_OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer your-token"
#
# Custom service name and environment (optional, defaults: entelechy-api, development)
 ENTELECHY_API_OTEL_SERVICE_NAME=entelechy-production
 ENTELECHY_API_OTEL_DEPLOYMENT_ENVIRONMENT=production
