# PostgreSQL Configuration
ENTELECHY_DB_USER=entelechy_user
ENTELECHY_DB_PASSWORD=change-me-to-secure-password
ENTELECHY_DB_NAME=entelechy_db

# Entelechy Version
ENTELECHY_VERSION=latest

# LLM Configuration
ENTELECHY_API_LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Alternative LLM providers (uncomment and configure as needed):
# ENTELECHY_API_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ENTELECHY_API_LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key

# ENTELECHY_API_LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key

# Vector and Text Search (already configured in docker-compose.yaml)
# ENTELECHY_API_VECTOR_EXTENSION=pgvectorscale
# ENTELECHY_API_TEXT_SEARCH_EXTENSION=pg_textsearch
