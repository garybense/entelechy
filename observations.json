    },
    {
      "id": "e6418201-461a-46bc-a5b8-397eb1177761",
      "text": "Entelechy utilizes soul-specific types with version lineage and first-class identity presets to encode identity as dense tokens and track history across banks.",
      "context": "",
      "date": "2026-05-02T04:45:18+00:00",
      "fact_type": "observation",
