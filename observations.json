    },
    {
      "id": "4eff1a90-6895-4d89-8fbe-eb29735219e7",
      "text": "Maintaining embedding space purity is critical for the performance of recall and reflect functions, as pollution from unrelated domains degrades performance into semantic noise.",
      "context": "",
      "date": "2026-05-03T18:04:00+00:00",
      "fact_type": "observation",
      "mentioned_at": "2026-05-03T18:04:00+00:00",
