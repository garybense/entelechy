    {
      "id": "0d50f567-230e-468e-a470-dff1c3593f15",
      "text": "Entelechy's patent strategy and product marketability focus on two central innovations: the State Reconstruction Loop (Claim 1) and Memory-Weighted Policy Modulation (Claim 2).",
      "context": "",
      "date": "2026-05-05T12:21:00.030000+00:00",
      "fact_type": "observation",
      "mentioned_at": "2026-05-05T12:32:00.010000+00:00",
