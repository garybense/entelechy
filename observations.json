    },
    {
      "id": "49d1746e-11f2-4942-8907-363044280650",
      "text": "Core memory operations in Entelechy consist of Retain (LLM extraction), Recall (parallel retrieval with reranking), and Reflect (disposition-aware synthesis).",
      "context": "",
      "date": "2026-05-02T04:44:52.310527+00:00",
      "fact_type": "observation",
      "mentioned_at": "2026-05-02T04:44:52.310527+00:00",
