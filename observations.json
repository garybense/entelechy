    },
    {
      "id": "61570dc2-053e-4659-9575-f150321d0a95",
      "text": "The state reconstruction process utilizes weighted episodic memory graphs, temporal decay functions, and retrieval-conditioned synthesis to generate a structured state vector.",
      "context": "",
      "date": "2026-05-05T12:21:00.010000+00:00",
      "fact_type": "observation",
      "mentioned_at": "2026-05-05T12:21:00.010000+00:00",
      "occurred_start": null,
