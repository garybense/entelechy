    {
      "id": "f90f00b9-1de9-472e-abf7-e815e324b472",
      "text": "Mental Models are pinned reflections in Entelechy that consolidate knowledge and serve as analogs to metacog soul encodings to refresh and maintain information.",
      "context": "",
      "date": "2026-05-02T04:44:52.320527+00:00",
