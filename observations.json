      "consolidation_failed_at": null
    },
    {
      "id": "5496f0dd-b897-4421-b7c7-c382707e21ce",
      "text": "Directives function as standing instructions that map to metacog covenants, though the system now prioritizes a Reconstructed State Vector as an authoritative control signal instead of static instructions.",
      "context": "",
      "date": "2026-05-02T04:44:52.330527+00:00",
      "fact_type": "observation",
      "mentioned_at": "2026-05-08T13:14:46.510451+00:00",
