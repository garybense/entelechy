    {
      "id": "623d5dad-d5ba-4919-be1c-acc0675d78a1",
      "text": "Entelechy implements 'Memory-Weighted Policy Modulation' (Primitive 2), which uses memory frequency, recency, and semantic clustering as behavioral weighting parameters to modulate inference-time behaviors such as verbosity and reasoning depth.",
      "context": "",
      "date": "2026-05-05T12:32:00+00:00",
